{
  "name": "idle-monster-farm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:pages": "tsc && vite build --base=/Idle-Monster-Farm/",
    "preview": "vite preview",
    "android:add": "npx cap add android",
    "android:build:web": "npm run build",
    "android:sync": "npm run build && npx cap sync android",
    "android:open": "npx cap open android"
  },
  "dependencies": {
    "@capacitor-community/admob": "^7.2.0",
    "@capacitor/android": "^7.6.5",
    "@capacitor/core": "^7.6.5",
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.5",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
