# Local browser builds use mock rewarded ads by default.
VITE_ADS_PROVIDER=mock

# Set this to admob for Android native builds with real rewarded ads.
# VITE_ADS_PROVIDER=admob

# Optional testing flag for AdMob SDK initialization and rewarded requests.
VITE_ADMOB_TESTING=true

# Android rewarded ad unit IDs. Use Google test IDs only while testing.
# Production IDs must come from the app owner's AdMob account.
VITE_ADMOB_REWARDED_DEFAULT_ANDROID=
VITE_ADMOB_REWARDED_SAFE_RITUAL_ANDROID=
VITE_ADMOB_REWARDED_BOSS_REVIVE_ANDROID=
VITE_ADMOB_REWARDED_BOSS_FIRST_CLEAR_X2_ANDROID=
VITE_ADMOB_REWARDED_BOSS_AUTO_CLEAR_X2_ANDROID=

# Android AdMob app ID for native metadata. This is wired during Android prep.
VITE_ADMOB_APP_ID_ANDROID=
